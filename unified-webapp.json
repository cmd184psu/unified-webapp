{
  "port": 8787,
  "tls_cert": "",
  "tls_key": "",
  "host_routing": {
    "todo.cmdhome.net":       "todo",
    "grocery.cmdhome.net":    "grocery",
    "ntphub.cmdhome.net":     "slideshow",
    "menuserver.cmdhome.net": "menuserver",
    "obsidianoid.cmdhome.net": "obsidianoid"
  },
  "grocery": {
    "static_dir": "./web/grocery",
    "data_file": "./data/grocery.json",
    "groups": [
      "Produce",
      "Meats",
      "mid store",
      "back wall",
      "frozen",
      "deli area near front"
    ],
    "progress": false,
    "sync_interval_seconds": 1,
    "title": "Grocery List"
  },
  "todo": {
    "static_dir": "./web/todo",
    "data_dir": "./data/todo",
    "ext": "json",
    "default_subject": "home",
    "sync_interval_seconds": 1
  },
  "slideshow": {
    "static_dir": "./web/slideshow",
    "image_dir": "./data/slideshow",
    "prefix": "slides",
    "default_subject": ""
  },
  "menuserver": {
    "static_dir": "./web/menuserver",
    "data_dir": "./data/menuserver",
    "show_all_pages": false
  },
  "obsidianoid": {
    "static_dir": "./web/obsidianoid",
    "data_dir": "./data/obsidianoid",
    "vaults": [
      { "path": "/opt/Vaults/Work", "name": "Cloudian", "theme": "forest" },
      { "path": "/opt/Vaults/Personal", "name": "Personal", "theme": "dark" }
    ],
    "threads_folder": "Threads",
    "thread_count": 4,
    "autosave_disabled": false
  }
}
